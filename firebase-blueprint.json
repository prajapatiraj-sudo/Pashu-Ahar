{
  "entities": {
    "User": {
      "title": "User",
      "description": "Application user with roles",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "sales"] }
      },
      "required": ["uid", "email", "role"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Customer details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "village": { "type": "string" },
        "total_outstanding": { "type": "number" }
      },
      "required": ["name", "phone"]
    },
    "Product": {
      "title": "Product",
      "description": "Product details",
      "type": "object",
      "properties": {
        "name_en": { "type": "string" },
        "name_gu": { "type": "string" },
        "unit": { "type": "string" },
        "price": { "type": "number" },
        "purchase_price": { "type": "number" },
        "stock_quantity": { "type": "number" }
      },
      "required": ["name_en", "name_gu", "price"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Sales invoice",
      "type": "object",
      "properties": {
        "customer_id": { "type": "string" },
        "customer_name": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "subtotal": { "type": "number" },
        "previous_outstanding": { "type": "number" },
        "total_amount": { "type": "number" },
        "paid_amount": { "type": "number" },
        "balance_due": { "type": "number" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "product_id": { "type": "string" },
              "name": { "type": "string" },
              "name_gu": { "type": "string" },
              "quantity": { "type": "number" },
              "rate": { "type": "number" },
              "purchase_price": { "type": "number" },
              "amount": { "type": "number" }
            }
          }
        }
      },
      "required": ["customer_id", "date", "total_amount"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Customer payment record",
      "type": "object",
      "properties": {
        "customer_id": { "type": "string" },
        "customer_name": { "type": "string" },
        "amount": { "type": "number" },
        "method": { "type": "string" },
        "note": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["customer_id", "amount", "date"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "Customer records"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product catalog"
    },
    "/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "Sales invoices"
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Customer payments"
    }
  }
}
