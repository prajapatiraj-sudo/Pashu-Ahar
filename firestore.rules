rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - name: string
    //   - role: string (required, ['admin', 'sales'])
    //
    // Collection: customers
    // Fields:
    //   - name: string (required)
    //   - phone: string (required)
    //   - address: string
    //   - total_outstanding: number
    //
    // Collection: products
    // Fields:
    //   - name_en: string (required)
    //   - name_gu: string (required)
    //   - unit: string
    //   - price: number (required)
    //   - purchase_price: number
    //   - stock_quantity: number
    //
    // Collection: invoices
    // Fields:
    //   - customer_id: string (required)
    //   - customer_name: string
    //   - date: timestamp (required)
    //   - subtotal: number
    //   - previous_outstanding: number
    //   - total_amount: number (required)
    //   - paid_amount: number
    //   - balance_due: number
    //   - items: list (required)
    //
    // Collection: payments
    // Fields:
    //   - customer_id: string (required)
    //   - customer_name: string
    //   - amount: number (required)
    //   - method: string
    //   - note: string
    //   - date: string or timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "rajkumar.prajapati@enjayworld.com" && request.auth.token.email_verified == true)
      );
    }

    function isSales() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'sales' || isAdmin()
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Validators
    function isValidUser(data) {
      return data.email is string && 
             data.role in ['admin', 'sales'] &&
             (!('name' in data) || data.name is string);
    }

    function isValidCustomer(data) {
      return data.name is string && data.name.size() > 0 &&
             data.phone is string &&
             (!('address' in data) || data.address is string) &&
             (!('village' in data) || data.village is string) &&
             (!('total_outstanding' in data) || data.total_outstanding is number) &&
             (!('deleted' in data) || data.deleted is bool) &&
             (!('deletedAt' in data) || data.deletedAt is timestamp || data.deletedAt == null);
    }

    function isValidProduct(data) {
      return data.name_en is string &&
             data.name_gu is string &&
             data.price is number &&
             (!('unit' in data) || data.unit is string) &&
             (!('purchase_price' in data) || data.purchase_price is number) &&
             (!('stock_quantity' in data) || data.stock_quantity is number) &&
             (!('deleted' in data) || data.deleted is bool) &&
             (!('deletedAt' in data) || data.deletedAt is timestamp || data.deletedAt == null);
    }

    function isValidInvoice(data) {
      return data.customer_id is string &&
             (data.date is timestamp || data.date is string) &&
             data.total_amount is number &&
             data.items is list &&
             (!('deleted' in data) || data.deleted is bool) &&
             (!('deletedAt' in data) || data.deletedAt is timestamp || data.deletedAt == null);
    }

    function isValidPayment(data) {
      return data.customer_id is string &&
             data.amount is number &&
             (data.date is timestamp || data.date is string) &&
             (!('deleted' in data) || data.deleted is bool) &&
             (!('deletedAt' in data) || data.deletedAt is timestamp || data.deletedAt == null);
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && isAdmin();
      allow delete: if isAdmin();
    }

    match /customers/{customerId} {
      allow read: if isSales();
      allow create: if isSales() && isValidCustomer(request.resource.data);
      allow update: if isSales() && isValidCustomer(request.resource.data);
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if isSales();
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /invoices/{invoiceId} {
      allow read: if isSales();
      allow create: if isSales() && isValidInvoice(request.resource.data);
      allow update: if isSales() && isValidInvoice(request.resource.data);
      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isSales();
      allow create: if isSales() && isValidPayment(request.resource.data);
      allow update: if isSales() && isValidPayment(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
